# Copy this file to `.env` and fill in real values. Never commit `.env`.

# --- Supabase (backend, server-side only) ---
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service_role_key>
# Anon (publishable) key. Used only for the login flow so the service_role
# client never has a user session attached to it.
SUPABASE_ANON_KEY=<anon_key>
SUPABASE_JWKS_URL=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_ISSUER=https://<project-ref>.supabase.co/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated

# --- App ---
# Deep link used as redirect_to for the admin password-reset email. This is
# the only remaining email-link flow. Members are created directly by admin
# (no invite email), and there is no signup email confirmation. The URL must
# be allow-listed in Supabase Dashboard -> Auth -> URL Configuration.
APP_DEEP_LINK=myapp://auth/callback

# --- Test-only (used by backend/tests, optional) ---
# When set, integration tests run against this Supabase project.
# When unset, those tests are skipped (never mocked).
TEST_SUPABASE_URL=
TEST_SUPABASE_SERVICE_ROLE_KEY=
TEST_SUPABASE_ANON_KEY=
TEST_SUPABASE_JWKS_URL=
TEST_SUPABASE_JWT_ISSUER=
TEST_SUPABASE_JWT_AUDIENCE=authenticated
